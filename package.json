{
  "name": "nexus",
  "private": true,
  "scripts": {
    "dev": "pnpm run build:web && NEXUS_PROJECT_DIR=$PWD tsx watch packages/server/src/cli.ts",
    "dev:full": "NEXUS_PROJECT_DIR=$PWD pnpm -r --parallel dev",
    "build:web": "pnpm --filter @nexus/web build",
    "build": "pnpm -r build",
    "start": "NEXUS_PROJECT_DIR=$PWD node --import tsx packages/server/src/cli.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "node-pty"
    ]
  }
}
